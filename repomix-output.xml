                  <div>
                    <label className="block text-sm font-semibold text-stone-700 mb-1.5">
                      Địa điểm
                    </label>
                    <div className="relative">
                      <MapPin className="absolute left-4 top-1/2 -translate-y-1/2 size-4 text-stone-400" />
                      <input
                        type="text"
