##
## Gia Phả OS — Environment Variables Example
## Copy this file to .env.local and fill in the values
## .env.local is gitignored — never commit real secrets
##

# ──────────────────────────────────────────────────────────
# Supabase (existing — see Supabase dashboard)
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ──────────────────────────────────────────────────────────
# AI Advisor — LLM Proxy Configuration
# ──────────────────────────────────────────────────────────
# Base URL of your LLM proxy (no trailing slash)
# Example (Google AI Studio OpenAI-compatible endpoint):
#   https://generativelanguage.googleapis.com/v1beta/openai
# Example (OpenRouter):
#   https://openrouter.ai/api/v1
PROXY_BASE_URL=https://your-llm-proxy.example.com/v1

# API key for the proxy (passed as Authorization: Bearer header)
PROXY_API_KEY=your-proxy-api-key-here

# ──────────────────────────────────────────────────────────
# Phone OTP Authentication (OTP Gateway + Supabase admin)
# ──────────────────────────────────────────────────────────
# Service role key is required for admin auth operations in OTP verify flow
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OTP Gateway provider settings
OTP_GATEWAY_API_KEY=ogw_your_api_key_here
OTP_GATEWAY_REQUEST_URL=https://otp-gateway.viethomes-jp.workers.dev/v1/partner/otp/request
OTP_GATEWAY_VERIFY_URL=https://otp-gateway.viethomes-jp.workers.dev/v1/partner/otp/verify

# Legacy fallback key name (optional during migration only)
# SPEEDSMS_ACCESS_TOKEN=legacy-key-if-needed

# Security salts for OTP internals (use long random secrets in production)
OTP_CODE_SALT=replace-with-random-secret
OTP_PASSWORD_PEPPER=replace-with-random-secret

# Optional: verbose OTP flow logs in server console ("true" or "1")
OTP_DEBUG_LOG=false
