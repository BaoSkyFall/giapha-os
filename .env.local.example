##
## Gia Phả OS — Environment Variables Example
## Copy this file to .env.local and fill in the values
## .env.local is gitignored — never commit real secrets
##

# ──────────────────────────────────────────────────────────
# Supabase (existing — see Supabase dashboard)
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ──────────────────────────────────────────────────────────
# AI Advisor — LLM Proxy Configuration
# ──────────────────────────────────────────────────────────
# Base URL of your LLM proxy (no trailing slash)
# Example (Google AI Studio OpenAI-compatible endpoint):
#   https://generativelanguage.googleapis.com/v1beta/openai
# Example (OpenRouter):
#   https://openrouter.ai/api/v1
PROXY_BASE_URL=https://your-llm-proxy.example.com/v1

# API key for the proxy (passed as Authorization: Bearer header)
PROXY_API_KEY=your-proxy-api-key-here
