# -----------------------------------------------------------------------------
# Tộc Phạm Phú - MẪU BIẾN MÔI TRƯỜNG CẤU HÌNH (ENVIRONMENT VARIABLES)
# -----------------------------------------------------------------------------
# Hướng dẫn:
# 1. Chép (copy) file này thành ".env.local"
# 2. Điền các giá trị thực tế tương ứng với dự án Supabase của bạn

# Tên của ứng dụng web được hiển thị cho người dùng
SITE_NAME="Tộc Phạm Phú"

# URL của project Supabase (Lấy từ Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Khóa Public (Lấy từ Settings > API > Project API keys > anon / public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-public-key"
CLOUDINARY_URL="cloudinary://<your_api_key>:<your_api_secret>@yourid"

# External AI backend URL (Python Flask/FastAPI server)
BACK_END_AI_URL="http://localhost:5000"

# ---------------------------------------------------------------------------
# OTP Auth (Phone + OTP Gateway v2.4)
# ---------------------------------------------------------------------------
# Required for server-side admin auth operations
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# OTP Gateway credentials
OTP_GATEWAY_API_KEY="ogw_your_api_key_here"
OTP_GATEWAY_REQUEST_URL="https://otp-gateway.viethomes-jp.workers.dev/v1/partner/otp/request"
OTP_GATEWAY_VERIFY_URL="https://otp-gateway.viethomes-jp.workers.dev/v1/partner/otp/verify"

# Legacy fallback key name (optional during migration only)
# SPEEDSMS_ACCESS_TOKEN="legacy-key-if-needed"

# OTP security secrets
OTP_CODE_SALT="replace-with-random-secret"
OTP_PASSWORD_PEPPER="replace-with-random-secret"
OTP_DEBUG_LOG="false"
