# -----------------------------------------------------------------------------
# Tộc Phạm Phú - MẪU BIẾN MÔI TRƯỜNG CẤU HÌNH (ENVIRONMENT VARIABLES)
# -----------------------------------------------------------------------------
# Hướng dẫn:
# 1. Chép (copy) file này thành ".env.local"
# 2. Điền các giá trị thực tế tương ứng với dự án Supabase của bạn

# Tên của ứng dụng web được hiển thị cho người dùng
SITE_NAME="Tộc Phạm Phú"

# URL của project Supabase (Lấy từ Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Khóa Public (Lấy từ Settings > API > Project API keys > anon / public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"
CLOUDINARY_URL="cloudinary://<your_api_key>:<your_api_secret>@yourid"

# External AI backend URL (Python Flask/FastAPI server)
BACK_END_AI_URL="http://localhost:5000"